---
import { cn } from "../utils/cn";

const {
  class: className,
  designation,
  company,
  duration,
  description,
} = Astro.props;
---

<div
  class={cn(
    "w-full border rounded xl:py-14 lg:py-12 md:py-10 py-8 lg:px-8 md:px-6 px-4 lg:space-y-10 md:space-y-8 space-y-5",
    className,
  )}
>
  <div class="flex justify-between flex-col sm:flex-row gap-5">
    <div class="sm:space-y-2 space-x-1">
      <h3>{designation}</h3>
      <h5>{company}</h5>
    </div>
    <h6>{duration}</h6>
  </div>
  <p>{description}</p>
</div>
