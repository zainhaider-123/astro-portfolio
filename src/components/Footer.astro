---
export interface navLink {
  name: string;
  href: string;
}

const navLinks: navLink[] = [
  { name: "About Me", href: "#about-me" },
  { name: "Experience", href: "#experience" },
  { name: "Projects", href: "#projects" },
  { name: "Contact", href: "#contact" },
];
---

<footer class="sec-padding pb-0">
  <div class="container mx-auto px-5 sm:text-left text-center">
    <div class="grid grid-cols-5 xl:gap-16 lg:gap-12 gap-10">
      <div class="lg:col-span-2 sm:col-span-5 col-span-5">
        <h3 class="font-bold capitalize sm:max-w-md">
          let's <span class="font-londrina">talk</span> for something <span
            class="font-londrina">special</span
          >
        </h3>
        <p class="mt-5 sm:max-w-2xl">
          Lorem ipsum dolor sit, amet consectetur adipisicing elit. Explicabo,
          earum ab facilis vel atque debitis, aut possimus repudiandae suscipit
          nobis ipsa mollitia consectetur sapiente itaque voluptatibus ut
          voluptas placeat ratione!
        </p>
      </div>
      <div class="lg:col-span-1 sm:col-span-2 col-span-5">
        <h4 class="font-bold capitalize">quick link</h4>
        <ul class="mt-6 md:space-y-6 space-y-4">
          {
            navLinks.map((link) => (
              <li>
                <a href={link.href} class="line-hover">
                  {link.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="lg:col-span-2 sm:col-span-3 col-span-5">
        <h4 class="font-bold capitalize">Get in Touch</h4>
        <form action="">
          <div class="mt-6 flex flex-col gap-4">
            <input
              type="email"
              name="email"
              placeholder="example@email.com"
              id=""
              class="w-full border-[1.5px] border-foreground/80 p-2 rounded-lg"
            />
            <button
              type="submit"
              class="w-full border-2 border-foreground bg-foreground text-background p-2 rounded-lg"
            >
              Send
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
  <div class="text-background bg-foreground">
    <div class="container mx-auto px-5">
      <div
        class="flex sm:flex-row flex-col text-center justify-between 2xl:mt-20 xl:mt-16 lg:mt-12 md:mt-10 mt-8 py-4 items-center"
      >
        <a
          href="/"
          class="lg:text-2xl md:text-xl text-lg font-londrina font-bold hover:text-foreground/80 duration-150"
        >
          Zain Haider
        </a>
        <a href="mailto:haiderzain@gmail.com" class="">
          haiderzain@gmail.com
        </a>
      </div>
    </div>
  </div>
</footer>
